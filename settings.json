      "WebFetch(domain:ref.rerun.io)",
      "Bash(.venv/bin/python -c \"import rerun.blueprint as rrb; import inspect; members = inspect.getmembers\\(rrb\\); theme_related = [m for m in members if ''theme'' in m[0].lower\\(\\) or ''background'' in m[0].lower\\(\\)]; print\\(''\\\\n''.join\\([f''{m[0]}: {type\\(m[1]\\).__name__}'' for m in theme_related]\\)\\)\")",
      "Bash(.venv/bin/python -c \"import rerun.blueprint as rrb; help\\(rrb.Background\\)\")",
      "Bash(.venv/bin/python -c \"import rerun.blueprint as rrb; help\\(rrb.BackgroundKind\\)\")",
      "Bash(.venv/bin/python -c \"from rerun import blueprint as rrb; print\\(dir\\(rrb\\)\\)\")",
      "Bash(.venv/bin/python -c \"from rerun import blueprint as rrb; print\\([x for x in dir\\(rrb\\) if ''theme'' in x.lower\\(\\) or ''style'' in x.lower\\(\\)]\\)\")",
      "Bash(.venv/bin/python -c \"from rerun import blueprint as rrb; help\\(rrb.PlotBackground\\)\")",
      "Bash(.venv/bin/python -c \"from rerun import blueprint as rrb; import inspect; sig = inspect.signature\\(rrb.Blueprint.__init__\\); print\\(sig\\)\")",
      "Bash(.venv/bin/python:*)",
      "Bash(gh api *)",
      "Skill(pr-review-toolkit:review-pr)",
      "Skill(pr-review-toolkit:review-pr:*)",
      "Skill(deep-research)",
      "Skill(deep-research:*)"
    ]
